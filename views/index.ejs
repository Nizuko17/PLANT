<%- include('partials/header') %>

    <main>
        <!-- Hero Section -->
        <section class="hero-section text-center">
            <div class="container fade-in">
                <h1 class="hero-title">Natura ed eleganza,<br>nelle tue mani.</h1>
                <p class="hero-subtitle">Scopri PLANT. Il vaso intelligente che si prende cura del tuo verde domestico.</p>
                <div class="hero-cta">
                    <a href="/prodotti" class="btn btn-primary">Acquista ora</a>
                    <a href="#scopri" class="btn btn-secondary">Scopri di più <i data-lucide="chevron-down" style="width:18px;height:18px;"></i></a>
                </div>
                <div class="hero-image-wrapper mt-5">
                    <img src="/assets/hero.png" alt="PLANT - Vaso Intelligente in ambiente moderno" class="hero-img">
                </div>
            </div>
        </section>

        <!-- Product Presentation -->
        <section id="scopri" class="features-section">
            <div class="container">
                <div class="feature-grid">
                    <div class="feature-text fade-in">
                        <h2>Perfetto in ogni dettaglio.</h2>
                        <p>Costruito con una struttura bicolore moderna: una parte superiore bianca opaca con il nostro iconico logo in rilievo, e una base verde chiaro semi-trasparente che rivela il futuro della cura botanica. Un design minimalista che si fonde perfettamente con l'estetica di casa tua.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Tech Section -->
        <section class="tech-section bg-light">
            <div class="container">
                <div class="tech-grid">
                    <div class="tech-image-wrapper fade-in">
                        <img src="/assets/tech.png" alt="Tecnologia interna sensori di PLANT" class="tech-img">
                    </div>
                    <div class="tech-text fade-in">
                        <h2>Cervello smart,<br>cuore verde.</h2>
                        <p>All'interno del design pulito si nasconde una sofisticata tecnologia basata su sensori di precisione, per garantirti che le tue piante ricevano sempre le cure esatte di cui hanno bisogno.</p>
                        <ul class="tech-list">
                            <li><i data-lucide="droplets"></i> Monitoraggio umidità del terreno</li>
                            <li><i data-lucide="thermometer"></i> Sensore temperatura integrato</li>
                            <li><i data-lucide="activity"></i> Rilevamento costante del pH</li>
                            <li><i data-lucide="smartphone"></i> Irrigazione automatica via App</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Mission Highlights -->
        <section class="mission-section text-center">
            <div class="container fade-in">
                <h2>La nostra Missione</h2>
                <div class="mission-cards">
                    <div class="mission-card">
                        <i data-lucide="leaf"></i>
                        <h4>Cura del verde</h4>
                        <p>Riportiamo la natura all'interno degli spazi urbani, offrendo alle tue piante l'ambiente perfetto per prosperare.</p>
                    </div>
                    <div class="mission-card">
                        <i data-lucide="waves"></i>
                        <h4>Risparmio Idrico</h4>
                        <p>Grazie all'irrigazione intelligente, PLANT fornisce acqua solo quando necessario, evitando sprechi.</p>
                    </div>
                    <div class="mission-card">
                        <i data-lucide="cpu"></i>
                        <h4>Innovazione</h4>
                        <p>Connettiamo la natura alla rete per offrirti un controllo totale tramite la nostra app dedicata.</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

<%- include('partials/footer') %>
