<%- include('partials/header') %>

    <main>
        <!-- Prodotti Hero -->
        <section class="page-hero text-center">
            <div class="container fade-in">
                <h1 class="hero-title">I nostri Prodotti</h1>
                <p class="hero-subtitle">Tecnologia e natura, progettate per la tua casa.</p>
            </div>
        </section>

        <!-- Products Grid -->
        <section class="products-section">
            <div class="container">
                <div class="products-grid">
                    <div class="product-card fade-in">
                        <div class="product-image">
                            <img src="/assets/hero.png" alt="PLANT One">
                        </div>
                        <div class="product-info">
                            <h3>PLANT One</h3>
                            <p class="product-desc">Il vaso intelligente essenziale. Sensori di umidità e temperatura integrati.</p>
                            <div class="product-price">&euro; 89,00</div>
                            <a href="#" class="btn btn-primary">Acquista</a>
                        </div>
                    </div>
                    <div class="product-card fade-in">
                        <div class="product-image">
                            <img src="/assets/hero.png" alt="PLANT Pro">
                        </div>
                        <div class="product-info">
                            <h3>PLANT Pro</h3>
                            <p class="product-desc">Irrigazione automatica, sensore pH e connettività Wi-Fi avanzata.</p>
                            <div class="product-price">&euro; 149,00</div>
                            <a href="#" class="btn btn-primary">Acquista</a>
                        </div>
                    </div>
                    <div class="product-card fade-in">
                        <div class="product-image">
                            <img src="/assets/hero.png" alt="PLANT Max">
                        </div>
                        <div class="product-info">
                            <h3>PLANT Max</h3>
                            <p class="product-desc">La soluzione completa: serbatoio integrato, pannello solare e app dedicata.</p>
                            <div class="product-price">&euro; 229,00</div>
                            <a href="#" class="btn btn-primary">Acquista</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Features Comparison -->
        <section class="comparison-section bg-light">
            <div class="container text-center fade-in">
                <h2>Confronta i modelli</h2>
                <div class="comparison-table-wrapper">
                    <table class="comparison-table">
                        <thead>
                            <tr>
                                <th>Funzionalità</th>
                                <th>One</th>
                                <th>Pro</th>
                                <th>Max</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr><td>Sensore umidità</td><td><i data-lucide="check"></i></td><td><i data-lucide="check"></i></td><td><i data-lucide="check"></i></td></tr>
                            <tr><td>Sensore temperatura</td><td><i data-lucide="check"></i></td><td><i data-lucide="check"></i></td><td><i data-lucide="check"></i></td></tr>
                            <tr><td>Irrigazione automatica</td><td><i data-lucide="x"></i></td><td><i data-lucide="check"></i></td><td><i data-lucide="check"></i></td></tr>
                            <tr><td>Sensore pH</td><td><i data-lucide="x"></i></td><td><i data-lucide="check"></i></td><td><i data-lucide="check"></i></td></tr>
                            <tr><td>Connettività Wi-Fi</td><td><i data-lucide="x"></i></td><td><i data-lucide="check"></i></td><td><i data-lucide="check"></i></td></tr>
                            <tr><td>Pannello solare</td><td><i data-lucide="x"></i></td><td><i data-lucide="x"></i></td><td><i data-lucide="check"></i></td></tr>
                            <tr><td>App dedicata</td><td><i data-lucide="x"></i></td><td><i data-lucide="x"></i></td><td><i data-lucide="check"></i></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>

<%- include('partials/footer') %>
